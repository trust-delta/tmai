{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-docs-temp/main/docs/.vitepress/public/schema-2.0.0-rc.json",
  "productName": "tmai",
  "version": "0.20.0",
  "identifier": "com.trustdelta.tmai",
  "build": {
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "web" },
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "web" },
    "devUrl": "http://localhost:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "tmai",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
